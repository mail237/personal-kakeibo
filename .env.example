# コピーして .env.local にリネームして値を入れてください

GEMINI_API_KEY=

# 任意: 使うモデルを1つに固定（未指定なら Lite→Flash を自動で順に試す）
# GEMINI_MODEL=gemini-2.0-flash-lite

# スプレッドシートの ID（URL の /d/ の後ろ）
SPREADSHEET_ID=

# Google Apps Script を「ウェブアプリ」としてデプロイしたURL（/exec で終わる）
GAS_WEBAPP_URL=

# clasp で gas/Code.gs を push するときに必要（Apps Script の「スクリプト ID」）
# GAS_SCRIPT_ID=

# GAS 側で検証する共有シークレット（長めのランダム文字列）
GAS_SHARED_SECRET=
